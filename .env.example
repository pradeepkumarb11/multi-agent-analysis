# ============================================================
# Multi-Agent LLM Data Analysis System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Groq (free LLM inference) ---
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase (Postgres database) ---
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # anon/public key

# --- Upstash Redis (job queue) ---
# Get from: https://console.upstash.com → Database → Details → REST URL
# Use the rediss:// (TLS) URL, NOT the REST URL
UPSTASH_REDIS_URL=rediss://default:xxxxxxxxxxxxxxxx@xxxx.upstash.io:6379

# --- LangSmith tracing (optional but recommended, free tier) ---
# Get from: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=multi-agent-analysis

# --- Frontend (set in Vercel dashboard, not here) ---
# VITE_API_URL=https://multi-agent-api.onrender.com
